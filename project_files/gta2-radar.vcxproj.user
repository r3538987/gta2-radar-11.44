<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='ReleaseII|Win32'">
    <LocalDebuggerCommand>$(GTA_II_DIR)\gta2.exe</LocalDebuggerCommand>
    <LocalDebuggerWorkingDirectory>$(GTA_II_DIR)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='DebugII|Win32'">
    <LocalDebuggerCommand>$(GTA_II_DIR)\gta2.exe</LocalDebuggerCommand>
    <LocalDebuggerWorkingDirectory>$(GTA_II_DIR)</LocalDebuggerWorkingDirectory>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
  </PropertyGroup>
</Project>